# API provider configuration
# Preferred: set `GEMINI_API_KEY` and `GEMINI_API_URL` to use Gemini.
# If you do not provide Gemini vars, the server will fall back to OpenRouter when `OPENROUTER_API_KEY` is set.
GEMINI_API_KEY=
GEMINI_API_URL=

# (Legacy / fallback) OpenRouter API key
OPENROUTER_API_KEY=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

# Optional: Customize these if needed
ORIGIN=http://localhost:5173
HTTP_REFERER=http://localhost:5173
APP_TITLE=Alpha Chat App

# Node Environment
NODE_ENV=production
